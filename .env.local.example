# Supabase — shared project hosting both admissions tables (ay{YYYY}_enrolment_*)
# and the grading schema (academic_years, students, grading_sheets, ...).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key — server-only, never expose to the browser.
# Used for the admissions roster read and all privileged API routes.
SUPABASE_SERVICE_KEY=

# PDF service URL — reserved, currently unused.
# The Python/WeasyPrint service from the original plan is deferred; the report
# card preview page uses the browser's Print / Save as PDF dialog instead.
# See Sprint 6 decision note in docs/sprints/development-plan.md.
PDF_SERVICE_URL=

# Parent portal URL — where the SIS sends parents back to if the
# handoff at /parent/enter fails (missing/expired tokens, setSession error).
# Should point at the authenticated parent-portal dashboard so returning
# parents land logged-in, not at a sign-in screen.
#
# Per-environment values (set these in Vercel → Settings → Environment
# Variables, one per environment — do NOT hardcode one here and ship it
# to production):
#
#   Production : https://enrol.hfse.edu.sg/admission/dashboard
#   Preview    : https://online-admission-staging.vercel.app/admission/dashboard
#   Development: https://online-admission-staging.vercel.app/admission/dashboard
#
# The value below is for local dev only. See docs/context/10-parent-portal.md
# § "Parent portal → SIS handoff" for the full per-environment setup.
NEXT_PUBLIC_PARENT_PORTAL_URL=https://online-admission-staging.vercel.app/admission/dashboard

# Resend — transactional email for parent report-card publication
# notifications and change-request state transitions. Server-only.
# If unset, the notification helpers silently no-op so local dev works
# without the dep (see lib/notifications/email-parents-publication.ts
# and lib/notifications/email-change-request.ts). In non-production
# (NODE_ENV !== 'production') every email is redirected to a static
# dev address regardless of recipient.
RESEND_API_KEY=

# Optional. Defaults to "HFSE SIS <noreply@hfse.edu.sg>" when unset.
# Must be a verified sender on the Resend account.
RESEND_FROM_EMAIL=
